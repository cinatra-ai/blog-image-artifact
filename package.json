{
  "name": "@cinatra-ai/blog-image-artifact",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "devDependencies": {
    "@cinatra-ai/sdk-extensions": "*"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "artifact",
    "dependencies": [],
    "artifact": {
      "accepts": {
        "file": {
          "mimeTypes": [
            "image/png",
            "image/jpeg",
            "image/webp"
          ]
        }
      },
      "skills": {
        "matchers": [
          "@cinatra-ai/blog-image-artifact:blog-image-matcher"
        ]
      },
      "matcherConfidenceThreshold": 0.7
    }
  }
}
